{
  "name": "@mcp/web-components",
  "version": "1.0.0",
  "description": "Web Components analyzer for MCP Code Analysis",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest --reporter verbose",
    "test:coverage": "vitest run --coverage --reporter verbose",
    "test:ui": "vitest --ui",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@mcp/core": "workspace:*",
    "lit-html": "^3.1.0",
    "ignite-element": "^1.4.5",
    "xstate": "^5.19.2"
  },
  "devDependencies": {
    "@mcp/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
} 