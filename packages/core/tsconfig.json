{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "composite": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@mcp/*": ["../*/src"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../types" }, { "path": "../xstate" }, { "path": "../utils" }]
}
