{
  "version": "1.0",
  "mcpServers": {
    "codeAnalysis": {
      "name": "Code Analysis MCP",
      "url": "http://localhost:3000/mcp",
      "description": "AI-powered code analysis and suggestions",
      "tools": [
        {
          "name": "analyze_code",
          "description": "Analyze code for improvements and suggestions",
          "parameters": {
            "code": {
              "type": "string",
              "description": "Source code to analyze"
            }
          }
        },
        {
          "name": "get_complexity_metrics",
          "description": "Get code complexity metrics",
          "parameters": {
            "code": {
              "type": "string",
              "description": "Source code to analyze"
            }
          }
        },
        {
          "name": "analyze_web_component",
          "description": "Analyze web component code for best practices and performance",
          "parameters": {
            "code": {
              "type": "string",
              "description": "Web component source code to analyze"
            },
            "framework": {
              "type": "string",
              "description": "Framework used (vanilla, lit, ignite, etc)",
              "enum": ["vanilla", "lit", "ignite"]
            }
          }
        }
      ]
    }
  }
}
