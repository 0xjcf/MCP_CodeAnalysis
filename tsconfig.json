{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@mcp/*": ["packages/*/src"]
    }
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/xstate" },
    { "path": "packages/core" }
  ]
}
